# ─── Server ───────────────────────────────────────────────────────────────────
HTTP_PORT=3000
# Hosting providers usually set PORT automatically. Keep HTTP_PORT for local dev.
# PORT=10000
TUNNEL_DOMAIN=tunnels.com
TUNNEL_URL_MODE=subdomain
PUBLIC_TUNNEL_PROTOCOL=http
# Leave blank in production unless your public tunnel URLs need an explicit port.
PUBLIC_TUNNEL_PORT=3000
# In path mode, set this to your backend base URL, e.g. https://app.onrender.com.
PUBLIC_TUNNEL_BASE_URL=http://localhost:3000

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# For zero-setup local development, use the file-backed DB:
# DB_DRIVER=file
DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/tunnlify
# Set true for hosted Postgres providers that require TLS.
DATABASE_URL_SSL=false
# Or use individual fields:
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=tunnlify
# PGUSER=postgres
# PGPASSWORD=password

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ─── Bcrypt ───────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# Billing / Stripe
APP_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
BILLING_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_DEVELOPER_PRICE_ID=
STRIPE_TEAM_PRICE_ID=
# Optional overrides:
# STRIPE_SUCCESS_URL=http://localhost:5173/dashboard?billing=success
# STRIPE_CANCEL_URL=http://localhost:5173/settings?billing=cancelled
