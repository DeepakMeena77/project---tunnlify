# ─── Server ───────────────────────────────────────────────────────────────────
HTTP_PORT=3000
TUNNEL_DOMAIN=tunnels.com

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# For zero-setup local development, use the file-backed DB:
# DB_DRIVER=file
DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/tunnlify
# Or use individual fields:
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=tunnlify
# PGUSER=postgres
# PGPASSWORD=password

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ─── Bcrypt ───────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# Billing / Stripe
APP_URL=http://localhost:5173
STRIPE_SECRET_KEY=sk_test_change_me
STRIPE_WEBHOOK_SECRET=whsec_change_me
STRIPE_DEVELOPER_PRICE_ID=price_developer_inr_monthly
STRIPE_TEAM_PRICE_ID=price_team_inr_monthly
# Optional overrides:
# STRIPE_SUCCESS_URL=http://localhost:5173/dashboard?billing=success
# STRIPE_CANCEL_URL=http://localhost:5173/settings?billing=cancelled
